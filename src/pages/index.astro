---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bliss Jaspis — Full Stack Developer</title>
  <meta name="description" content="Resume of Bliss Jaspis, Full Stack Developer based in Jakarta, Indonesia. Builder of Goalkes and MyOpenTrip.">
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,700&display=swap" rel="stylesheet">
</head>
<body class="bg-white font-roboto text-resume-body antialiased">
  <main class="mx-auto max-w-4xl px-8 py-10 md:px-12 md:py-14">
    <header class="mb-10 flex items-center gap-5">
      <img
        src="/profile.png"
        alt="Bliss Jaspis"
        width="88"
        height="88"
        class="h-[88px] w-[88px] shrink-0 object-cover"
      />
      <div>
        <h1 class="text-[2rem] font-bold leading-tight text-resume-orange md:text-4xl">Bliss Jaspis</h1>
        <p class="mt-1 text-lg text-resume-body">Full Stack Developer</p>
      </div>
    </header>

    <div class="grid grid-cols-1 gap-10 md:grid-cols-[2fr_1fr] md:gap-12">
      <div class="space-y-8">
        <section>
          <h2 class="mb-3 text-lg font-bold text-resume-orange">Professional Summary</h2>
          <p class="text-[0.95rem] leading-relaxed">
            Full stack developer at PT. Goalkes Indonesia Jaya / PT. Fres Perkasa Nusantara Jaya,
            responsible for all web applications — including internal tools, marketing sites, and
            <a href="https://goalkes.com" class="text-blue-600 hover:text-blue-800 pl-1 no-underline hover:underline" target="_blank" rel="noopener noreferrer">goalkes.com </a>,
            a medical-device e-commerce platform built with Laravel, Next.js, and Tailwind CSS. Migrated
            the frontend from Vue.js to React, and contributed to early iOS and Android development.
            Maintains production infrastructure on DigitalOcean with Docker. Independently building
            <a href="https://myopentrip.com" class="text-blue-600 hover:text-blue-800 pl-1 no-underline hover:underline" target="_blank" rel="noopener noreferrer">myopentrip.com </a>,
            a travel e-commerce platform using the same core stack.
          </p>
        </section>

        <section>
          <h2 class="mb-4 text-lg font-bold text-resume-orange">Employment History</h2>
          <article>
            <h3 class="font-bold text-resume-body">
              Full Stack Developer at PT. Goalkes Indonesia Jaya / PT. Fres Perkasa Nusantara Jaya, Jakarta
            </h3>
            <p class="mt-1 text-sm text-resume-muted">Sept 2016 — Present</p>
            <ul class="mt-2 list-none space-y-2 pl-0 text-[0.95rem] leading-relaxed">
              <li>
                Initially developed
                <a href="https://goalkes.com" class="text-blue-600 hover:text-blue-800 pl-1 no-underline hover:underline" target="_blank" rel="noopener noreferrer">goalkes.com </a>
                and continue to handle all company websites — from an employee attendance system to
                product marketing sites — with primary focus on the Goalkes medical-device e-commerce platform.
              </li>
              <li>
                Build and maintain the stack using Laravel, Next.js, and Tailwind CSS; migrated the
                frontend from Vue.js to React during ongoing development.
              </li>
              <li>
                Contributed to early iOS and Android app development during the initial product phase.
              </li>
              <li>
                Set up and maintain production servers on DigitalOcean, using Docker for the main
                application alongside legacy deployments.
              </li>
            </ul>
          </article>
        </section>

        <section>
          <h2 class="mb-4 text-lg font-bold text-resume-orange">Projects</h2>
          <article>
            <h3 class="font-bold text-resume-body">
              <a href="https://myopentrip.com" class="text-resume-body hover:text-resume-orange" target="_blank" rel="noopener noreferrer">
                MyOpenTrip
              </a>
              — Founder &amp; Full Stack Developer
            </h3>
            <p class="mt-1 text-sm text-resume-muted">Personal project — Present</p>
            <ul class="mt-2 list-none space-y-2 pl-0 text-[0.95rem] leading-relaxed">
              <li>
                Self-built travel e-commerce platform at
                <a href="https://myopentrip.com" class="text-blue-600 hover:text-blue-800 pl-1 no-underline hover:underline" target="_blank" rel="noopener noreferrer">myopentrip.com </a>,
                covering product discovery, checkout, and seller communication end to end.
              </li>
              <li>
                Laravel and React with Tailwind CSS; Meilisearch for search, Redis for caching, and MySQL
                for data storage.
              </li>
              <li>
                Integrated Midtrans for online payments, with a chat-based inquiry flow for trips that
                require custom arrangements without an immediate transaction.
              </li>
              <li>
                Owns hosting, deployment, and release workflow on DigitalOcean.
              </li>
            </ul>
          </article>
        </section>

        <section>
          <h2 class="mb-4 text-lg font-bold text-resume-orange">Education</h2>
          <article>
            <h3 class="font-bold text-resume-body">Adventist University of Indonesia at Bandung</h3>
            <p class="mt-1 text-[0.95rem]">Bachelor of Informatics Engineering</p>
            <p class="mt-1 text-sm text-resume-muted">Aug 2010 — May 2016</p>
          </article>
        </section>
      </div>

      <aside class="space-y-6 text-[0.95rem]">
        <section>
          <h2 class="mb-1 font-bold text-resume-blue">Address</h2>
          <p>Bekasi, Indonesia</p>
        </section>

        <section>
          <h2 class="mb-1 font-bold text-resume-blue">Email</h2>
          <p>
            <a href="mailto:bliss@jaspis.me" class="text-blue-600 underline hover:text-blue-800">
              bliss@jaspis.me
            </a>
          </p>
        </section>

        <section>
          <h2 class="mb-1 font-bold text-resume-blue">Phone</h2>
          <p>+6281223752170</p>
        </section>

        <section>
          <h2 class="mb-2 font-bold text-resume-blue">Skills</h2>
          <ul class="list-none space-y-0.5 pl-0">
            <li>Laravel</li>
            <li>React.js</li>
            <li>Next.js</li>
            <li>Tailwind CSS</li>
            <li>MySQL</li>
            <li>Redis</li>
            <li>Meilisearch</li>
            <li>Docker</li>
            <li>DigitalOcean</li>
            <li>Midtrans</li>
            <li>Vue.js</li>
          </ul>
        </section>

        <section>
          <h2 class="mb-2 font-bold text-resume-blue">Languages</h2>
          <ul class="list-none space-y-0.5 pl-0">
            <li>English</li>
            <li>Indonesian</li>
          </ul>
        </section>

        <section>
          <h2 class="mb-2 font-bold text-resume-blue">Hobbies</h2>
          <ul class="list-none space-y-0.5 pl-0">
            <li>Driving</li>
          </ul>
        </section>
      </aside>
    </div>
  </main>
</body>
</html>
